# ==================== DATABASE ====================
DATABASE_URL="mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/libraryhub-pro?retryWrites=true&w=majority"

# ==================== AUTH ====================
AUTH_SECRET="libraryhub-pro-super-secret-key-32chars"
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="libraryhub-pro-super-secret-key-32chars"

# ==================== RAZORPAY ====================
RAZORPAY_KEY_ID="rzp_test_your_key_id"
RAZORPAY_KEY_SECRET="your_razorpay_secret"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_your_key_id"

# ==================== UPLOADTHING ====================
UPLOADTHING_SECRET="sk_live_your_uploadthing_secret"
UPLOADTHING_APP_ID="your_uploadthing_app_id"

# ==================== BREVO EMAIL ====================
BREVO_API_KEY="your_brevo_api_key"
BREVO_SENDER_EMAIL="noreply@yourdomain.com"
BREVO_SENDER_NAME="LibraryHub Pro"

# ==================== APP ====================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="LibraryHub Pro"

# ==================== CRON ====================
CRON_SECRET="your_cron_secret_key"

# ==================== WHATSAPP (Wap2b / Meta Cloud API) ====================
# Official WhatsApp Business Cloud API via Wap2b BSP
# Get credentials from: Meta Business Manager → WhatsApp → API Setup
# OR: Wap2b Dashboard → API Settings
WHATSAPP_PHONE_NUMBER_ID="your_phone_number_id_from_meta"
WHATSAPP_ACCESS_TOKEN="your_permanent_system_user_access_token"

# Template name that you've created & approved in Meta Business Manager
# Path: Meta Business Manager → WhatsApp Manager → Message Templates
# Template example body:
#   Hi {{1}}, your library fee at *{{5}}* is due in *{{2}} days* on {{3}}.
#   Amount: ₹{{4}}. Please pay on time. 🙏
WHATSAPP_FEE_REMINDER_TEMPLATE="fee_reminder"

# Language code: "en" for English, "hi" for Hindi
WHATSAPP_TEMPLATE_LANGUAGE="en"
